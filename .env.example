# ============================================
# RevealX - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# --------------------------------------------
# Database Configuration (Required)
# --------------------------------------------
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
# Example: postgres://postgres:password@localhost:5432/revealx
DATABASE_URL=

# --------------------------------------------
# Solana Blockchain Configuration (Required)
# --------------------------------------------
# Pool wallet private key (base58 encoded)
# This wallet holds prize funds and sends payouts
# CRITICAL: Keep this secret! Anyone with this key controls the pool funds.
POOL_WALLET_PRIVATE_KEY=

# Solana RPC URL (optional - has defaults)
# Mainnet options:
#   - https://api.mainnet-beta.solana.com (public, rate limited)
#   - https://rpc.helius.xyz/?api-key=YOUR_KEY (recommended)
#   - https://ssc-dao.genesysgo.net/ (fallback)
# Devnet: https://api.devnet.solana.com
SOLANA_RPC_URL=

# --------------------------------------------
# Frontend Environment Variables (Required)
# --------------------------------------------
# These are used by the client build
# Must be prefixed with VITE_ to be accessible in browser

# Solana Network: 'mainnet' or 'devnet'
VITE_SOLANA_NETWORK=mainnet

# Custom RPC URL for frontend (optional but recommended)
VITE_SOLANA_RPC_URL=

# Team wallet address (receives 10% of ticket sales)
VITE_TEAM_WALLET=

# Pool wallet address (public - for verification)
VITE_POOL_WALLET=

# Frontend URL for CORS (production only)
VITE_FRONTEND_URL=

# --------------------------------------------
# Base Chain Configuration (EVM)
# --------------------------------------------
# Base Network: 'mainnet' or 'sepolia'
BASE_NETWORK=mainnet

# Base RPC URL (optional - defaults to public endpoint)
# Recommended for production: Use Alchemy, Infura, or QuickNode
BASE_RPC_URL=https://mainnet.base.org

# Pool wallet private key (EVM format: 0x...)
# This wallet holds prize funds and sends payouts on Base
BASE_POOL_PRIVATE_KEY=0x...

# Frontend Base Configuration
VITE_BASE_NETWORK=mainnet
VITE_BASE_RPC_URL=https://mainnet.base.org

# Base pool wallet address (for frontend USDC transfer verification)
VITE_BASE_POOL_WALLET=0x...

# Base USDC contract (optional - defaults to known addresses)
# Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
VITE_BASE_USDC_CONTRACT=

# WalletConnect Project ID (required for MetaMask, Rainbow, etc.)
# Get one at: https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=

# --------------------------------------------
# Jackpot Configuration (Solana)
# --------------------------------------------
JACKPOT_MINT=
JACKPOT_TREASURY_TOKEN_ACCOUNT=
JACKPOT_TICKET_PRICE_TOKENS=1000
VITE_JACKPOT_MINT=
VITE_JACKPOT_TREASURY_TOKEN_ACCOUNT=
VITE_JACKPOT_TICKET_PRICE_TOKENS=1000

# --------------------------------------------
# API Keys (Optional but Recommended)
# --------------------------------------------
# Helius API key for better RPC reliability
HELIUS_API_KEY=

# Bags.fm API key (for token jackpot feature)
BAGS_API_KEY=

# --------------------------------------------
# Security Configuration
# --------------------------------------------
# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET=

# CORS origins (comma-separated for multiple)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Rate limiting (requests per minute per IP)
RATE_LIMIT_GENERAL=60
RATE_LIMIT_GAME_CREATION=10
RATE_LIMIT_PAYOUT=5

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# --------------------------------------------
# Monitoring & Logging (Optional)
# --------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Sentry DSN for error tracking
SENTRY_DSN=

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable/disable demo mode
ENABLE_DEMO_MODE=true

# Maintenance mode
MAINTENANCE_MODE=false

# --------------------------------------------
# Base v2 Contract Deployment (Foundry)
# --------------------------------------------
# Deployer EOA private key (used by forge script)
DEPLOYER_PRIVATE_KEY=0x...

# Owner address (Safe multisig recommended)
OWNER_ADDRESS=0x...

# Protocol fee recipient address
FEE_RECIPIENT=0x...

# Base USDC address
# Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Chainlink VRF v2.5 coordinator
# Mainnet: 0xd5D517aBE5cF79B7e95eC98dB0f0277788aFF634
# Sepolia: 0x5C210eF41CD1a72de73bF76eC39637bB0d3d7BEE
VRF_COORDINATOR=0x5C210eF41CD1a72de73bF76eC39637bB0d3d7BEE

# Chainlink VRF subscription ID (create and fund at https://vrf.chain.link)
VRF_SUBSCRIPTION_ID=1234

# Chainlink VRF key hash
# Base Sepolia 30 gwei: 0x9e1344a1247c8a1785d0a4681a27152bffdb43666ae5bf7d14d24a5efd44bf71
VRF_KEY_HASH=0x9e1344a1247c8a1785d0a4681a27152bffdb43666ae5bf7d14d24a5efd44bf71

# BaseScan API key for contract verification
BASESCAN_API_KEY=

# --------------------------------------------
# Indexer & Creator Dashboard
# --------------------------------------------
# Enable the Base contract event indexer worker
ENABLE_INDEXER=false

# Pinata JWT for IPFS pinning (optional; falls back to public IPFS gateway)
PINATA_JWT=

# v2 feature flag for Base (frontend)
VITE_V2_ENABLED_BASE=false
