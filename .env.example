# ============================================
# Scratch 'n SOL - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# --------------------------------------------
# Database Configuration (Required)
# --------------------------------------------
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
# Example: postgres://postgres:password@localhost:5432/scratchndsol
DATABASE_URL=

# --------------------------------------------
# Solana Blockchain Configuration (Required)
# --------------------------------------------
# Pool wallet private key (base58 encoded)
# This wallet holds prize funds and sends payouts
# CRITICAL: Keep this secret! Anyone with this key controls the pool funds.
POOL_WALLET_PRIVATE_KEY=

# Solana RPC URL (optional - has defaults)
# Mainnet options:
#   - https://api.mainnet-beta.solana.com (public, rate limited)
#   - https://rpc.helius.xyz/?api-key=YOUR_KEY (recommended)
#   - https://ssc-dao.genesysgo.net/ (fallback)
# Devnet: https://api.devnet.solana.com
SOLANA_RPC_URL=

# --------------------------------------------
# Frontend Environment Variables (Required)
# --------------------------------------------
# These are used by the client build
# Must be prefixed with VITE_ to be accessible in browser

# Solana Network: 'mainnet' or 'devnet'
VITE_SOLANA_NETWORK=mainnet

# Custom RPC URL for frontend (optional but recommended)
VITE_SOLANA_RPC_URL=

# Team wallet address (receives 10% of ticket sales)
VITE_TEAM_WALLET=

# Pool wallet address (public - for verification)
VITE_POOL_WALLET=

# Frontend URL for CORS (production only)
VITE_FRONTEND_URL=

# --------------------------------------------
# Jackpot Configuration (Optional)
# --------------------------------------------
JACKPOT_MINT=
JACKPOT_TREASURY_TOKEN_ACCOUNT=
JACKPOT_TICKET_PRICE_TOKENS=1000
VITE_JACKPOT_MINT=
VITE_JACKPOT_TREASURY_TOKEN_ACCOUNT=
VITE_JACKPOT_TICKET_PRICE_TOKENS=1000

# --------------------------------------------
# API Keys (Optional but Recommended)
# --------------------------------------------
# Helius API key for better RPC reliability
HELIUS_API_KEY=

# Bags.fm API key (for token jackpot feature)
BAGS_API_KEY=

# --------------------------------------------
# Security Configuration
# --------------------------------------------
# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET=

# CORS origins (comma-separated for multiple)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Rate limiting (requests per minute per IP)
RATE_LIMIT_GENERAL=60
RATE_LIMIT_GAME_CREATION=10
RATE_LIMIT_PAYOUT=5

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# --------------------------------------------
# Monitoring & Logging (Optional)
# --------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Sentry DSN for error tracking
SENTRY_DSN=

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable/disable demo mode
ENABLE_DEMO_MODE=true

# Maintenance mode
MAINTENANCE_MODE=false
